---
import BTGLogo from "@/assets/img-logo.svg";
import CTA from "@/components/Cta.astro";
import Title from "@/components/Title.astro";
---

<section class="bg-btg-9 px-5">
  <div class="max-w-300 mx-auto bg-radial from-btg-55 to-btg-9 to-70% pt-14.5">
    <h1 aria-label="BTG Pactual">
      <BTGLogo class="w-45 md:w-53.5" />
    </h1>
    <div
      class="flex flex-col lg:flex-row justify-center gap-15 lg:gap-25 py-10 lg:py-20 text-white"
    >
      <Title marginTop="lg:mt-0" showMap={false} />
      <div
        class="form-wrapper lg:mt-20 mb-14.5 lg:mb-30 place-self-center shrink-0"
      >
        <CTA />
      </div>
    </div>
  </div>
</section>

<style>
  .form-wrapper {
    @media (min-width: 1024px) {
      width: clamp(30rem, -2.5rem + 50.7813vw, 38.125rem);
    }
  }
</style>
